# ==============================
# 필수 환경변수 (반드시 설정 필요)
# ==============================

# 관리자 로그인 비밀번호
ADMIN_PASSWORD=여기에_강력한_비밀번호_입력

# JWT 서명용 시크릿 키 (최소 32자 이상의 랜덤 문자열)
# 생성 예시: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=여기에_랜덤_시크릿_키_입력

# Turso(LibSQL) 데이터베이스 URL
DATABASE_URL=libsql://your-database.turso.io

# Turso 인증 토큰
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Vercel Blob 스토리지 토큰
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx
